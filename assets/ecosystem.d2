# SNN Research Ecosystem — teams and their latest SNN / neuromorphic work (2024–2026).
# Source of truth for the knowledge graph; rendered to assets/ecosystem.svg by
# .github/workflows/diagram.yml on every change. Edit this file, not the SVG.
#
# Legend: solid arrow = collaboration / shared output · dashed arrow = spin-off or
# academic lineage · blue = academic lab · amber = company.

vars: {
  d2-config: {
    layout-engine: dagre
    theme-id: 0
    pad: 20
  }
}

classes: {
  lab: {
    style: {
      fill: "#eff6ff"
      stroke: "#3b82f6"
      stroke-width: 2
      border-radius: 10
      font-color: "#0f172a"
    }
  }
  co: {
    style: {
      fill: "#fffbeb"
      stroke: "#f59e0b"
      stroke-width: 2
      border-radius: 10
      font-color: "#0f172a"
    }
  }
}

title: |md
  # 🧠 Spiking Neural Network Research Ecosystem
  ### teams · latest work (2024–2026) · collaborations & spin-offs
| {
  near: top-center
  style: { font-color: "#0f172a"; stroke-width: 0 }
}

map: {
  grid-columns: 2
  grid-gap: 50
  style: { stroke-width: 0; fill: transparent }

  China: {
    label: "🇨🇳 China"
    grid-columns: 3
    style: { fill: "#fef2f2"; stroke: "#fca5a5"; border-radius: 14; font-color: "#7f1d1d"; font-size: 22 }

    casia_lgq: { label: "CASIA · BICLab — Li Guoqi\n▸ SpikingBrain 7B/76B LLM (2025)"; class: lab }
    pku_tian: { label: "PKU — Tian Yonghong\n▸ SpikingJelly · TTFS training (2024)"; class: lab }
    pku_yu: { label: "PKU — Yu Zhaofei\n▸ Spike-camera reconstruction (AAAI 2025)"; class: lab }
    pku_huang: { label: "PKU / BAAI — Huang Tiejun\n▸ Low-light spike streams (2025)"; class: lab }
    uestc: { label: "UESTC — Zhang Malu\n▸ Sub-bit SNN · Saccadic ViT (ICLR 2025)"; class: lab }
    thu: { label: "Tsinghua · CBICR — Shi Luping\n▸ General-purpose brain computing (2024)"; class: lab }
    zju: { label: "ZJU — Pan Gang\n▸ DarwinWafer wafer-scale chip (2025)"; class: lab }
    casia_zy: { label: "CASIA — Zeng Yi\n▸ STEP spiking-transformer benchmark (2025)"; class: lab }
  }

  Americas: {
    label: "🌎 Americas"
    grid-columns: 3
    style: { fill: "#eef2ff"; stroke: "#a5b4fc"; border-radius: 14; font-color: "#3730a3"; font-size: 22 }

    purdue: { label: "Purdue · NRL — Kaushik Roy\n▸ SpiDR CIM accelerator (2025)"; class: lab }
    usc: { label: "USC · ICL — Priya Panda\n▸ STAtten spiking transformer (CVPR 2025)"; class: lab }
    ucsc: { label: "UC Santa Cruz — J. Eshraghian\n▸ Spike-based LLM (2025) · snnTorch"; class: lab }
    intel: { label: "Intel Labs — Mike Davies\n▸ Loihi 2 online continual learning (2025)"; class: lab }
    ibm: { label: "IBM Research — D. Modha\n▸ NorthPole LLM inference (2024)"; class: lab }
    stanford: { label: "Stanford — Kwabena Boahen\n▸ Dendrocentric FeFET device (2023)"; class: lab }
    waterloo: { label: "Waterloo — Chris Eliasmith\n▸ Spiking arm+locomotor control (2026)"; class: lab }
    utk: { label: "UT Knoxville — C. Schuman\n▸ Neuromorphic computing at scale (Nature 2025)"; class: lab }
    ucsd: { label: "UC San Diego — G. Cauwenberghs\n▸ HiAER-Spike 160M neurons (2025)"; class: lab }
  }

  Europe: {
    label: "🇪🇺 Europe"
    grid-columns: 4
    style: { fill: "#ecfeff"; stroke: "#67e8f9"; border-radius: 14; font-color: "#155e75"; font-size: 22 }

    ini_ind: { label: "INI Zürich — G. Indiveri\n▸ Mixed-signal SNN optimizer (2026)"; class: lab }
    ini_del: { label: "INI Zürich — Tobi Delbruck\n▸ Realistic DVS pixel model (2025)"; class: lab }
    ini_liu: { label: "INI Zürich — Shih-Chii Liu\n▸ Low-power speech adaptation (2026)"; class: lab }
    manchester: { label: "Manchester — Steve Furber\n▸ SpiNNaker2 robotics platform (2026)"; class: lab }
    epfl: { label: "EPFL · LCN — W. Gerstner\n▸ Self-supervised local learning (2026)"; class: lab }
    graz: { label: "TU Graz — Wolfgang Maass\n▸ Fast learning w/o plasticity (2024)"; class: lab }
    fmi: { label: "FMI Basel — F. Zenke\n▸ Prospective neurons (2025)"; class: lab }
    heidelberg: { label: "Heidelberg — J. Schemmel\n▸ BrainScaleS-2 multi-chip (2025)"; class: lab }
    cnrs: { label: "CNRS CerCo — T. Masquelier\n▸ DelRec learnable delays (2025)"; class: lab }
    julich: { label: "Jülich / RWTH — Emre Neftci\n▸ Sparse delay keyword SNN (2026)"; class: lab }
    delft: { label: "TU Delft — Charlotte Frenkel\n▸ TESS local learning rule (2025)"; class: lab }
    cwi: { label: "CWI — Sander Bohte\n▸ SpikingGamma online training (2026)"; class: lab }
    sussex: { label: "Sussex — Thomas Nowotny\n▸ Structural plasticity in GeNN (2025)"; class: lab }
    kcl: { label: "KCL — Bipin Rajendran\n▸ Neuromorphic wireless split computing (2025)"; class: lab }
    iit: { label: "IIT Genoa — C. Bartolozzi\n▸ Spiking ring-attractor proprioception (2026)"; class: lab }
  }

  APAC: {
    label: "🌏 Asia-Pacific"
    grid-columns: 1
    style: { fill: "#f0fdf4"; stroke: "#86efac"; border-radius: 14; font-color: "#166534"; font-size: 22 }

    cityu: { label: "CityU HK — Arindam Basu\n▸ NeuDW-CIM neuromorphic macro (2026)"; class: lab }
    polyu: { label: "PolyU · MIND — Jibin Wu\n▸ Neuromorphic Sequential Arena (2025)"; class: lab }
    wsu: { label: "Western Sydney · ICNS — G. Cohen\n▸ LAND neuromorphic datasets (2026)"; class: lab }
  }

  Industry: {
    label: "🏭 Companies"
    grid-columns: 2
    style: { fill: "#fffbeb"; stroke: "#fcd34d"; border-radius: 14; font-color: "#78350f"; font-size: 22 }

    synsense: { label: "SynSense 时识科技\n▸ Speck · Xylo · SNN astronomy (2025)"; class: co }
    lynxi: { label: "Lynxi 灵汐科技\n▸ KA200 · HP300 hybrid chips"; class: co }
    innatera: { label: "Innatera\n▸ Spiking Neural Processor T1 · Pulsar"; class: co }
    brainchip: { label: "BrainChip\n▸ Akida event-based edge SoC"; class: co }
  }
}

# ---- Relationships across the ecosystem ----

# Collaboration / shared output (solid)
map.China.casia_lgq -> map.APAC.polyu: "SpikingBrain\nco-development" {
  style: { stroke: "#2563eb"; stroke-width: 2; font-color: "#1e3a8a" }
}

# Academic lineage (dashed)
map.Americas.purdue -> map.Americas.usc: "PhD lineage" {
  style: { stroke: "#64748b"; stroke-dash: 4; font-color: "#475569" }
}

# Spin-offs (dashed)
map.Europe.ini_ind -> map.Industry.synsense: "spin-off" {
  style: { stroke: "#d97706"; stroke-dash: 4; font-color: "#92400e" }
}
map.Europe.delft -> map.Industry.innatera: "spin-off" {
  style: { stroke: "#d97706"; stroke-dash: 4; font-color: "#92400e" }
}
map.China.thu -> map.Industry.lynxi: "spin-off lineage" {
  style: { stroke: "#d97706"; stroke-dash: 4; font-color: "#92400e" }
}
