  // ---------- Americas ----------
  purdue    [label="Purdue\nK. Roy\nâ–¸SpiDR CIM '25"];
  usc       [label="USC\nP. Panda\nâ–¸STAtten '25"];
  ucsc      [label="UC Santa Cruz\nEshraghian\nâ–¸Spike-LLM '25"];
  intel     [label="Intel Labs\nM. Davies\nâ–¸Loihi 2 CL '25"];
  ibm       [label="IBM\nModha\nâ–¸NorthPole"];
  stanford  [label="Stanford\nBoahen\nâ–¸Dendrocentric"];
  waterloo  [label="Waterloo\nEliasmith\nâ–¸Nengo '26"];
  utk       [label="UT Knoxville\nSchuman\nâ–¸Nature '25"];
  ucsd      [label="UC San Diego\nCauwenberghs\nâ–¸HiAER-Spike '25"];
