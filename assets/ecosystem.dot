// SNN Research Ecosystem â€” force-directed knowledge graph.
// Teams (circles, colored by region) orbit a regional hub; each is tagged with
// its latest SNN work (2024-2026). Solid = collaboration, dashed = spin-off /
// lineage. Rendered to assets/ecosystem.svg by .github/workflows/diagram.yml.
graph ecosystem {
  layout=twopi;
  root=core;
  ranksep="4.6 equally";
  overlap=true;
  sep="+14";
  splines=curved;
  bgcolor="white";
  fontname="Helvetica,Arial,sans-serif";
  labelloc="t";
  fontsize=24;
  fontcolor="#0f172a";
  label="Spiking Neural Network Research Ecosystem\nteams & their latest work (2024â€“2026)";

  node [shape=circle, style="filled", fontname="Helvetica,Arial,sans-serif",
        fontsize=9, penwidth=2, margin=0.04, fixedsize=false];
  edge [color="#cbd5e1", penwidth=1.0];

  // ---------- core + regional hubs ----------
  core       [label="SNN\nEcosystem", shape=circle, fontsize=20, fillcolor="#0f172a", color="#0f172a", fontcolor="#ffffff", penwidth=0];
  core -- {China Americas Europe APAC Industry} [color="#e2e8f0", penwidth=2.4];
  China      [label="China",         shape=doublecircle, fontsize=18, fillcolor="#fecaca", color="#dc2626", fontcolor="#7f1d1d"];
  Americas   [label="Americas",      shape=doublecircle, fontsize=18, fillcolor="#c7d2fe", color="#4f46e5", fontcolor="#3730a3"];
  Europe     [label="Europe",        shape=doublecircle, fontsize=18, fillcolor="#a5f3fc", color="#0891b2", fontcolor="#155e75"];
  APAC       [label="Asia-Pacific",  shape=doublecircle, fontsize=18, fillcolor="#bbf7d0", color="#16a34a", fontcolor="#166534"];
  Industry   [label="Companies",     shape=doublecircle, fontsize=18, fillcolor="#fde68a", color="#d97706", fontcolor="#78350f"];

  // ---------- China ----------
  node [fillcolor="#eff6ff", color="#3b82f6", fontcolor="#0f172a"];
  casia_lgq [label="CASIAآ·BICLab\nLi Guoqi\nâ–¸SpikingBrain '25"];
  pku_tian  [label="PKU\nTian Yonghong\nâ–¸SpikingJelly"];
  pku_yu    [label="PKU\nYu Zhaofei\nâ–¸Spike-cam '25"];
  pku_huang [label="PKUآ·BAAI\nHuang Tiejun\nâ–¸Spike streams '25"];
  uestc     [label="UESTC\nZhang Malu\nâ–¸Sub-bit SNN '25"];
  thu       [label="Tsinghuaآ·CBICR\nShi Luping\nâ–¸Tianjic"];
  zju       [label="ZJU\nPan Gang\nâ–¸DarwinWafer '25"];
  casia_zy  [label="CASIA\nZeng Yi\nâ–¸STEP '25"];
