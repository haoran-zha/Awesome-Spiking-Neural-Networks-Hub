  // ---------- Europe ----------
  ini_ind   [label="INI Zأ¼rich\nIndiveri\nâ–¸DYNAP opt. '26"];
  ini_del   [label="INI Zأ¼rich\nDelbruck\nâ–¸DVS model '25"];
  ini_liu   [label="INI Zأ¼rich\nShih-Chii Liu\nâ–¸Audio '26"];
  manch     [label="Manchester\nFurber\nâ–¸SpiNNaker2 '26"];
  epfl      [label="EPFLآ·LCN\nGerstner\nâ–¸Local learn '26"];
  graz      [label="TU Graz\nMaass\nâ–¸LSNNآ·e-prop"];
  fmi       [label="FMI Basel\nZenke\nâ–¸Prospective '25"];
  heid      [label="Heidelberg\nSchemmel\nâ–¸BrainScaleS-2 '25"];
  cnrs      [label="CNRS CerCo\nMasquelier\nâ–¸DelRec '25"];
  julich    [label="Jأ¼lichآ·RWTH\nNeftci\nâ–¸Delay SNN '26"];
  delft     [label="TU Delft\nFrenkel\nâ–¸TESS '25"];
