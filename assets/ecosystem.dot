  // ---------- cross-ecosystem relationships ----------
  casia_lgq -- polyu    [label="SpikingBrain", color="#2563eb", penwidth=2.4, fontcolor="#1e3a8a", fontsize=9];
  purdue -- usc         [label="lineage", style=dashed, color="#64748b", fontcolor="#475569", fontsize=9];
  ini_ind -- synsense   [label="spin-off", style=dashed, color="#d97706", fontcolor="#92400e", fontsize=9];
  delft -- innatera     [label="spin-off", style=dashed, color="#d97706", fontcolor="#92400e", fontsize=9];
