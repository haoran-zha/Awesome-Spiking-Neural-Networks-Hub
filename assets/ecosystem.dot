  // ---------- Companies ----------
  node [fillcolor="#fffbeb", color="#f59e0b"];
  synsense  [label="SynSense\nو—¶è¯†ç§‘وٹ€\nâ–¸Speckآ·Xylo"];
  lynxi     [label="Lynxi çپµو±گ\nâ–¸KA200آ·HP300"];
  innatera  [label="Innatera\nâ–¸SNP T1آ·Pulsar"];
  brainchip [label="BrainChip\nâ–¸Akida"];
